# Edge Crew v3.0 API Gateway Environment Variables
# Copy this file to .env.local and customize for your environment

# =============================================================================
# JWT Secrets (Generate strong secrets for production)
# =============================================================================
JWT_SECRET_EDGE_WEB=your-secure-edge-web-secret-min-32-chars
JWT_SECRET_EDGE_MOBILE=your-secure-edge-mobile-secret-min-32-chars
JWT_SECRET_EDGE_ADMIN=your-secure-edge-admin-secret-min-32-chars
JWT_SECRET_INTERNAL=your-secure-internal-secret-min-32-chars

# =============================================================================
# Kong Configuration
# =============================================================================
KONG_DATABASE=off
KONG_DECLARATIVE_CONFIG=/kong/declarative/kong.yml
KONG_PLUGINS=bundled,edge-auth,edge-rate-limiting,edge-transform

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
RATE_LIMIT_MINUTE_DEFAULT=60
RATE_LIMIT_HOUR_DEFAULT=1000
RATE_LIMIT_POLICY=redis

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Authorization,Content-Type,X-Request-ID,X-API-Key
CORS_MAX_AGE=3600

# =============================================================================
# Monitoring Configuration
# =============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION=15d

# =============================================================================
# Development/Testing Flags
# =============================================================================
DEBUG=false
LOG_LEVEL=info
MOCK_SERVICES_ENABLED=true
