# Edge Crew v3.0 - Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================================================
# CORE SETTINGS
# =============================================================================

# Application environment: development, staging, production
NODE_ENV=development
PYTHON_ENV=development

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Enable debug mode (true/false)
DEBUG=false

# =============================================================================
# SECURITY
# =============================================================================

# JWT Secret for authentication (generate a strong random string)
# Example: openssl rand -base64 32
JWT_SECRET=dev-secret-key-change-in-production

# API Key for internal service communication
INTERNAL_API_KEY=internal-api-key-change-in-production

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL Connection URL
DATABASE_URL=postgresql://edgecrew:edgecrew@postgres:5432/edgecrew

# PostgreSQL Individual Settings (used by docker-compose)
POSTGRES_USER=edgecrew
POSTGRES_PASSWORD=edgecrew
POSTGRES_DB=edgecrew
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =============================================================================
# REDIS
# =============================================================================

# Redis Connection URL
REDIS_URL=redis://redis:6379

# Redis Individual Settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# AZURE AI SERVICES (REQUIRED for AI Processor)
# =============================================================================

# Azure Sweden Central AI Endpoint
AZURE_SWEDEN_ENDPOINT=https://swedencentral.api.cognitive.microsoft.com

# Azure AI API Key - REQUIRED
# Get this from Azure Portal -> Cognitive Services -> Keys and Endpoint
AZURE_SWEDEN_KEY=your-azure-key-here

# Azure AI Foundry (Sweden Central) — used by Analyze All real-AI calls
# Same key as AZURE_SWEDEN_KEY in most setups; AZURE_AI_KEY takes precedence.
AZURE_AI_KEY=your-azure-key-here
AZURE_AI_ENDPOINT=https://peter-mna31gr3-swedencentral.services.ai.azure.com/openai/v1/

# =============================================================================
# SPORTS DATA PROVIDERS
# =============================================================================

# Odds API Key (for sports odds data)
ODDS_API_KEY=your-odds-api-key-here

# SportsData.io API Key
SPORTSDATA_API_KEY=your-sportsdata-key-here

# ESPN API (if using direct ESPN access)
ESPN_API_KEY=

# =============================================================================
# WEB FRONTEND
# =============================================================================

# API URL for client-side requests
NEXT_PUBLIC_API_URL=http://localhost:8000

# API URL for server-side requests (internal Docker network)
API_INTERNAL_URL=http://api-gateway:8000

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# SERVICE URLs (Internal)
# =============================================================================

DATA_INGESTION_URL=http://data-ingestion:8080
GRADING_ENGINE_URL=http://grading-engine:8080
AI_PROCESSOR_URL=http://ai-processor:8080
CONVERGENCE_URL=http://convergence:8080

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable real-time WebSocket updates
ENABLE_WEBSOCKETS=true

# Enable AI predictions
ENABLE_AI_PREDICTIONS=true

# Enable grading automation
ENABLE_AUTO_GRADING=true

# Enable notifications
ENABLE_NOTIFICATIONS=true

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Enable Prometheus metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# OpenTelemetry configuration
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=edge-crew
OTEL_SERVICE_VERSION=3.0.0

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable hot reload for development
HOT_RELOAD=true

# Python debug mode
PYDEVD_DISABLE_FILE_VALIDATION=1

# Enable polling for file watching (useful on Windows/WSL)
CHOKIDAR_USEPOLLING=true

# =============================================================================
# EMAIL / NOTIFICATIONS (Optional)
# =============================================================================

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@edgecrew.local

# =============================================================================
# CLOUD SETTINGS (Production)
# =============================================================================

# AWS/Azure/GCP settings for production deployments
# CLOUD_PROVIDER=azure
# AZURE_RESOURCE_GROUP=
# AZURE_CONTAINER_REGISTRY=
# AZURE_STORAGE_ACCOUNT=
